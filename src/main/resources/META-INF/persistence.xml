<persistence-unit name="EmpresaPU" transaction-type="RESOURCE_LOCAL">
    <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
    <class>com.mycompany.bancojpa.entity.Empleado</class>
    <properties>
      <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/TuBaseDeDatos"/>
      <property name="jakarta.persistence.jdbc.user" value="TuUsuario"/>
      <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
      <property name="jakarta.persistence.jdbc.password" value="TuContraseña"/>
      <property name="jakarta.persistence.schema-generation.database.action" value="update"/>
    </properties>
</persistence-unit>